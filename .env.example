# Copy to .env (gitignored). docker compose reads it automatically.

# REQUIRED: absolute path to your read-only archive on the host.
MSGBROWSE_ARCHIVE_HOST=/Users/you/Managed Files/Signal-Archive

# Model names msgbrowse asks LiteLLM for (must match litellm.config.yaml).
MSGBROWSE_LLM_CHAT_MODEL=local-chat
MSGBROWSE_LLM_EMBED_MODEL=local-embed

# Only if your LiteLLM route requires a key (a local Ollama route does not).
MSGBROWSE_LLM_API_KEY=

# Provider keys, only if litellm.config.yaml routes to a HOSTED provider.
# Leaving these empty keeps everything local.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
